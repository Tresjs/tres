{
  "name": "tresjs",
  "version": "0.1.0",
  "private": true,
  "description": "Official monorepo for TresJS",
  "keywords": [
    "3d",
    "three",
    "threejs",
    "threejs-vue",
    "vue"
  ],
  "license": "MIT",
  "author": "Alvaro Saburido <hola@alvarosaburido.dev> (https://github.com/alvarosabu/)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tresjs/tres.git"
  },
  "workspaces": [
    "packages/*",
    "tools/*",
    "apps/*"
  ],
  "type": "module",
  "scripts": {
    "build": "vp run -r build",
    "build:ci": "vp run -F '@tresjs/*' build",
    "dev": "vp run -r dev",
    "lint": "vp check && eslint .",
    "lint:fix": "vp check --fix && eslint . --fix",
    "test": "vp test",
    "monocubo": "node tools/monocubo/dist/index.js",
    "sponsorkit": "npx sponsorkit",
    "release": "nx release --skip-publish --group=core",
    "release:version": "nx release version",
    "release:dry-run": "nx release --dry-run --skip-publish --group=core",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@nx/js": "^22.4.4",
    "nx": "22.4.4",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@10.20.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ],
    "overrides": {
      "ipx": "3.0.2"
    }
  }
}
